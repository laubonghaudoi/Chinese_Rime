---
import PlaceholderBand from "./PlaceholderBand.astro";
import ConsonantGrid from "./ConsonantGrid.astro";
import FinalGrid from "./FinalGrid.astro";
import PhonologyListTable from "./PhonologyListTable.astro";
import SoonBadge from "./SoonBadge.astro";
import SyllableIndex from "./SyllableIndex.astro";
import TonesTable from "./TonesTable.astro";
import type { PhonologySummaryEntry } from "../data/types";
import { withBase } from "../utils/path";

interface Props {
  index: "01" | "02" | "03" | "04";
  title: string;
  intro: string;
  variant?: "panel" | "elev";
  data?: PhonologySummaryEntry | null;
}

const { index, title, intro, variant = "panel", data = null } = Astro.props;
const shouldRender = !(index === "03" && data && data.tones.length === 0);
const hasData = Boolean(data && (
  (index === "01" && (data.initials_grid || data.initials.length > 0)) ||
  (index === "02" && (data.finals_grid || data.finals.length > 0)) ||
  (index === "03" && data.tones.length > 0) ||
  (index === "04" && data.preview_syllables.length > 0)
));
const sectionIntro = hasData ? intro : `本方案的${title}尚待自動解析或人工補充。`;
---
{shouldRender && (
  <section class:list={["syl", `bg-${variant}`]}>
    <span class="label">音系資料 · {index}</span>
    <div class="head">
      <h2>{title}</h2>
      {!hasData && <SoonBadge />}
    </div>
    <p>{sectionIntro}</p>
    {hasData && data ? (
      <>
        {index === "01" && data.initials_grid && <ConsonantGrid grid={data.initials_grid} />}
        {index === "01" && !data.initials_grid && data.initials.length > 0 && <PhonologyListTable entries={data.initials} kind="initial" />}
        {index === "02" && data.finals_grid && <FinalGrid grid={data.finals_grid} />}
        {index === "02" && !data.finals_grid && data.finals.length > 0 && <PhonologyListTable entries={data.finals} kind="final" />}
        {index === "03" && <TonesTable tones={data.tones} />}
        {index === "04" && (
          <SyllableIndex
            entries={data.preview_syllables}
            fetchUrl={withBase(data.asset_path)}
            total={data.stats.total_chars}
          />
        )}
      </>
    ) : (
      <PlaceholderBand variant={variant} />
    )}
  </section>
)}

<style>
  .syl {
    padding: 42px var(--sp-section-x) 36px;
  }
  .bg-panel {
    background: var(--bg-panel);
  }
  .bg-elev {
    background: var(--bg-elev);
  }
  .label {
    display: inline-block;
    margin-bottom: 12px;
    padding: 2px 8px;
    background: var(--zhu-tint);
    color: var(--zhu);
    font-family: var(--ff-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
  }
  .head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  h2 {
    margin: 0;
    font-family: var(--ff-serif-tc);
    font-size: var(--fs-h2-section);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: 0;
  }
  p {
    max-width: 720px;
    margin: 0 0 18px;
    color: var(--ink-meta-2);
    font-family: var(--ff-serif-tc);
    font-size: 15.5px;
    line-height: 1.7;
  }
</style>
