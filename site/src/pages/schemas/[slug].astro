---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import MetaSheet from "../../components/MetaSheet.astro";
import SchemaHero from "../../components/SchemaHero.astro";
import SchemaRow from "../../components/SchemaRow.astro";
import SyllableSection from "../../components/SyllableSection.astro";
import { getBranchByKey, getManifest, getPhonologySummary, getSchema, getSiblingSchemas, hasPhonology } from "../../data/loader";
import { dialectAnchor } from "../../utils/anchors";
import { withBase } from "../../utils/path";

export function getStaticPaths() {
  return Object.values(getManifest().schemas).map((schema) => ({
    params: { slug: schema.slug },
    props: { schemaId: schema.schema_id }
  }));
}

const { schemaId } = Astro.props as { schemaId: string };
const schema = getSchema(schemaId);
const branch = schema.branch ? getBranchByKey(schema.branch) : null;
const siblings = getSiblingSchemas(schema.schema_id);
const phonology = getPhonologySummary(schema.schema_id);
const crumbs = [
  { label: "方案目錄", href: withBase("/catalog/") },
  ...(branch ? [{ label: branch.name, href: withBase(`/catalog/#${branch.key}`) }] : []),
  ...(branch && schema.dialect ? [{ label: schema.dialect, href: withBase(`/catalog/#${encodeURIComponent(dialectAnchor(branch.key, schema.dialect))}`) }] : []),
  { label: schema.display_name }
];
---
<BaseLayout title={`${schema.display_name} · 非普通話漢語拼音方案全集`} active="catalog">
  <Breadcrumb items={crumbs} />
  <SchemaHero schema={schema} hasPhonology={Boolean(phonology)} />
  <MetaSheet schema={schema} />

  <SyllableSection index="01" title="聲母表" intro="由碼表推得的聲母、例字與覆蓋字數。" variant="panel" data={phonology} />
  <SyllableSection index="02" title="韻母表" intro="由碼表推得的韻母、例字與覆蓋字數。" variant="elev" data={phonology} />
  <SyllableSection index="03" title="聲調" intro="由拼寫尾碼或附加符號推得的聲調分佈。" variant="panel" data={phonology} />
  <SyllableSection index="04" title="字音對照" intro="依單字碼表整理的字與拼寫對照，可搜尋完整資料。" variant="elev" data={phonology} />

  {siblings.length > 0 && (
    <section class="related">
      <span class="lab">同方言其他方案</span>
      <h2>更多{schema.dialect}方案</h2>
      <div class="related-grid">
        {siblings.map((sibling) => <SchemaRow schema={sibling} hasPhonology={hasPhonology(sibling.schema_id)} />)}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .related {
    padding: 42px var(--sp-section-x) 36px;
  }
  .related {
    background: var(--bg-panel);
  }
  .lab {
    display: block;
    margin-bottom: 10px;
    color: var(--ink-meta-3);
    font-family: var(--ff-sans-tc);
    font-size: var(--fs-label);
    letter-spacing: var(--ls-label);
  }
  h2 {
    margin: 0 0 14px;
    font-family: var(--ff-serif-tc);
    font-size: var(--fs-h2-section);
    letter-spacing: 0;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
